POSTGRES_DB=nutricore_manager
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_PORT=5432

SPRING_PROFILES_ACTIVE=homolog
BACKEND_PORT=8080
FRONTEND_PORT=4173

JWT_SECRET=change-me-with-at-least-32-characters
JWT_ISSUER=nutricore-manager-homolog
JWT_ACCESS_TOKEN_TTL=PT8H
APP_CORS_ALLOWED_ORIGINS=https://homolog.seu-dominio.com

MEDIA_STORAGE_PATH=/app/storage/editorial-media

# Bootstrap deve ficar desligado por padrão em homologação.
# Habilite apenas no primeiro boot se precisar criar o admin inicial.
APP_SECURITY_BOOTSTRAP_ENABLED=false
APP_SECURITY_BOOTSTRAP_FULL_NAME=
APP_SECURITY_BOOTSTRAP_EMAIL=
APP_SECURITY_BOOTSTRAP_PASSWORD=
APP_SECURITY_BOOTSTRAP_ROLE=ADMIN
